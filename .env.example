# Mesh Mint — Environment Configuration
# Copy this file to .env and fill in the values.
#
# SECURITY: .env is gitignored and MUST NOT be committed.
# Variables prefixed with VITE_ are bundled into the client build.
# In production, use Pinata presigned URLs via a server-side endpoint
# so the JWT never reaches the browser. See:
# https://docs.pinata.cloud/files/presigned-urls

# Anchor program ID (deployed on devnet)
VITE_MESH_MINT_PROGRAM_ID=3z9VVHRqRW8ywzy2mtkpmDAGMjqgGkz8iz1dtXGs75xH

# Pinata IPFS — required for 3D model uploads
# Get your JWT at https://app.pinata.cloud/developers/api-keys
# WARNING: This JWT is exposed in the client bundle. Use a key with
# upload-only permissions (no delete, no admin). For production,
# generate presigned URLs server-side instead.
VITE_PINATA_JWT=

# Your Pinata dedicated gateway domain (without https://)
# Fallback gateways (ipfs.io, cloudflare-ipfs.com) are used automatically
# if the primary is unavailable.
VITE_PINATA_GATEWAY=gateway.pinata.cloud

# Optional overrides
# VITE_SOLANA_CLUSTER=devnet
# VITE_SOLANA_RPC_URL=
# VITE_TREASURY_WALLET=AAaJbDC4HsLyHb59iFovqgAZpe39WDHnE9DRdUXErxEY
